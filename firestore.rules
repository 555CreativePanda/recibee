rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // For maximum security in production, you can require verified emails.
      // However, to ensure a smooth developer experience and support various auth providers,
      // we only require the user to be signed in for basic ownership checks.
      return isSignedIn();
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.get('email', '') == 'chandra.mayur@gmail.com' && request.auth.token.get('email_verified', false) == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidRecipe(data) {
      return (!('title' in data) || (data.title is string && data.title.size() <= 300)) &&
             (!('ingredients' in data) || (data.ingredients is list && data.ingredients.size() <= 200)) &&
             (!('steps' in data) || (data.steps is list && data.steps.size() <= 200)) &&
             (isAdmin() || !('user_id' in data) || data.user_id == request.auth.uid) &&
             (!('is_public' in data) || data.is_public is bool) &&
             (!('parent_id' in data) || data.parent_id == null || data.parent_id == "" || data.parent_id is string);
    }

    function isValidFeatureRequest(data) {
      return data.keys().hasAll(['title', 'description', 'user_id']) &&
             data.title is string && 
             data.description is string && 
             data.user_id == request.auth.uid;
    }

    // ===============================================================
    // Resource Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if true;
      allow list: if false; 
      
      allow create: if isOwner(userId) || (
        isVerified() &&
        incoming().keys().hasOnly(['star_count']) &&
        incoming().star_count == 1
      );

      allow update: if isOwner(userId) || (
        isVerified() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['star_count'])
      );

      match /private/data {
        allow read, write: if isOwner(userId);
      }
    }

    match /recipes/{recipeId} {
      allow read: if isAdmin() || 
                    (resource == null) || 
                    (resource.data.is_public == true) ||
                    (!('is_public' in resource.data)) ||
                    (isSignedIn() && resource.data.user_id == request.auth.uid);
      allow create: if isVerified() && isValidRecipe(incoming());
      allow update: if isVerified() && (
        isAdmin() || (
          existing().user_id == request.auth.uid &&
          isValidRecipe(incoming())
        ) || (
          incoming().diff(existing()).affectedKeys().hasOnly(['star_count', 'fork_count'])
        )
      );
      allow delete: if isVerified() && (isAdmin() || existing().user_id == request.auth.uid);
    }

    match /stars/{starId} {
      allow read: if isSignedIn() && (resource == null || resource.data.user_id == request.auth.uid);
      allow write: if isSignedIn() && (
        (request.resource != null && request.resource.data.user_id == request.auth.uid) ||
        (resource != null && resource.data.user_id == request.auth.uid)
      );
    }

    match /feature_requests/{featureId} {
      allow read: if true;
      allow create: if isVerified() && isValidFeatureRequest(incoming());
      allow update: if isVerified() && (
        isAdmin() || 
        (resource != null && existing().user_id == request.auth.uid) ||
        (resource != null && incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'score']))
      );
    }

    match /feature_votes/{voteId} {
      allow read: if isVerified() && (resource == null || resource.data.user_id == request.auth.uid);
      allow create: if isVerified() && incoming().user_id == request.auth.uid && voteId == request.auth.uid + '_' + incoming().feature_id;
      allow delete: if isVerified() && (resource != null && existing().user_id == request.auth.uid);
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
    }

    match /_internal_/{document=**} {
      allow read: if true;
    }
  }
}
