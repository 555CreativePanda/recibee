rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidRecipe(data) {
      return data.keys().hasAll(['title', 'ingredients', 'steps', 'user_id']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.ingredients is list && data.ingredients.size() <= 100 &&
             (data.ingredients.size() == 0 || data.ingredients[0] is string) &&
             data.steps is list && data.steps.size() <= 100 &&
             (data.steps.size() == 0 || (data.steps[0] is string || data.steps[0] is map)) &&
             data.user_id == request.auth.uid &&
             (!('source_url' in data) || data.source_url == null || (data.source_url is string && data.source_url.size() <= 2000)) &&
             (!('parent_id' in data) || data.parent_id == null || isValidId(data.parent_id)) &&
             (!('star_count' in data) || data.star_count is number) &&
             (!('fork_count' in data) || data.fork_count is number) &&
             (!('created_at' in data) || data.created_at is timestamp) &&
             (!('updated_at' in data) || data.updated_at is timestamp);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid == request.auth.uid &&
             (!('displayName' in data) || data.displayName is string && data.displayName.size() <= 100) &&
             (!('photoURL' in data) || data.photoURL is string && data.photoURL.size() <= 2000) &&
             (!('bio' in data) || data.bio is string && data.bio.size() <= 500);
    }

    function isValidStar(data) {
      return data.keys().hasAll(['recipe_id', 'user_id']) &&
             data.user_id == request.auth.uid &&
             isValidId(data.recipe_id) &&
             exists(/databases/$(database)/documents/recipes/$(data.recipe_id));
    }

    function isValidFeatureRequest(data) {
      return data.keys().hasAll(['title', 'description', 'user_id']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             data.user_id == request.auth.uid;
    }

    // ===============================================================
    // Resource Rules
    // ===============================================================

    match /users/{userId} {
      allow get: if isVerified();
      allow list: if false; // Prevention of user scraping
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'updated_at']) &&
                       (!('updated_at' in incoming()) || incoming().updated_at == request.time);

      match /private/data {
        allow read, write: if isOwner(userId);
      }
    }

    match /recipes/{recipeId} {
      allow get: if isVerified();
      allow list: if isVerified() && resource.data.user_id != null; 
      allow create: if isVerified() && isValidRecipe(incoming()) && isValidId(recipeId);
      allow update: if isVerified() && (
        isAdmin() || (
          existing().user_id == request.auth.uid &&
          isValidRecipe(incoming()) &&
          incoming().user_id == existing().user_id &&
          incoming().created_at == existing().created_at &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'title', 'ingredients', 'steps', 'prep_time', 'cook_time', 'servings', 
            'cuisine', 'course', 'equipment', 'keywords', 'notes', 'source_url', 'updated_at'
          ]) &&
          (!('updated_at' in incoming()) || incoming().updated_at == request.time)
        ) || (
          // System updates (likes/forks count)
          incoming().diff(existing()).affectedKeys().hasOnly(['star_count', 'fork_count'])
        )
      );
      allow delete: if isVerified() && (isAdmin() || existing().user_id == request.auth.uid);
    }

    match /stars/{starId} {
      allow get: if isVerified() && resource.data.user_id == request.auth.uid;
      allow list: if isVerified() && resource.data.user_id == request.auth.uid;
      allow create: if isVerified() && isValidStar(incoming()) && starId == request.auth.uid + '_' + incoming().recipe_id;
      allow delete: if isVerified() && existing().user_id == request.auth.uid;
    }

    match /feature_requests/{featureId} {
      allow get: if isVerified();
      allow list: if isVerified() && resource.data.user_id != null;
      allow create: if isVerified() && isValidFeatureRequest(incoming());
      allow update: if isVerified() && (
        isAdmin() || (
          existing().user_id == request.auth.uid && 
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description'])
        ) || (
          // Upvote logic
          incoming().diff(existing()).affectedKeys().hasOnly(['upvotes', 'score'])
        )
      );
    }

    match /feature_votes/{voteId} {
      allow read: if isVerified() && resource.data.user_id == request.auth.uid;
      allow create: if isVerified() && incoming().user_id == request.auth.uid && voteId == request.auth.uid + '_' + incoming().feature_id;
      allow delete: if isVerified() && existing().user_id == request.auth.uid;
    }
  }
}
